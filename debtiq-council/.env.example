# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model + cadence (optional) ───────────────────────────────────────────────
# Use Sonnet/Haiku for the continuous loop; Opus for occasional deep rounds.
COUNCIL_MODEL=claude-sonnet-4-6
# Seconds between rounds in continuous mode (no flag given).
COUNCIL_INTERVAL=900
# Max output tokens per advisor call.
COUNCIL_MAX_TOKENS=1400
# Sampling temperature for the advisors (0–1).
COUNCIL_TEMPERATURE=0.7

# ── Red-flag alerting (optional) ─────────────────────────────────────────────
# Flags at or above this severity (1–5) ping you. Default 4.
SEVERITY_THRESHOLD=4
# Any Slack/Discord-style "post JSON" incoming webhook.
ALERT_WEBHOOK_URL=
# …or a Telegram bot. Both must be set to use Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Desktop notifications are attempted automatically. Set to 0 to disable.
DESKTOP_NOTIFY=1
