<script>
/* PARTICLES */
(()=>{
  const cv=document.getElementById('pcv'), cx=cv.getContext('2d');
  let W,H,pts=[];
  const resize=()=>{ W=cv.width=innerWidth; H=cv.height=innerHeight; };
  addEventListener('resize',resize); resize();
  for(let i=0;i<48;i++) pts.push({
    x:Math.random()*1800, y:Math.random()*1200,
    vx:(Math.random()-.5)*.14, vy:(Math.random()-.5)*.11,
    r:Math.random()*1.1+.3, a:Math.random()*.35+.08
  });
  const draw=()=>{
    cx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      p.x=(p.x+p.vx+W)%W; p.y=(p.y+p.vy+H)%H;
      cx.beginPath(); cx.arc(p.x,p.y,p.r,0,Math.PI*2);
      cx.fillStyle=`rgba(212,175,55,${p.a})`; cx.fill();
    });
    requestAnimationFrame(draw);
  };
  draw();
})();

/* PROGRESS */
addEventListener('scroll',()=>{
  const d=document.documentElement;
  document.getElementById('prog').style.width=(d.scrollTop/(d.scrollHeight-d.clientHeight)*100)+'%';
});

/* PARALLAX */
addEventListener('scroll',()=>{
  const y=scrollY;
  const b=document.querySelector('.hero-bg');
  const m=document.querySelector('.mandap-wrap');
  if(b) b.style.transform=`translateY(${y*.28}px)`;
  if(m) m.style.transform=`translateX(-50%) translateY(${y*.14}px)`;
});

/* SCROLL REVEALS */
const io=new IntersectionObserver(es=>{
  es.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('vis'); });
},{threshold:.12});
[
  '.quote-text','.quote-line',
  '.clabel','.cheadline','.cdetails','.jasmine',
  '.vlabel','.vname','.vaddr','.map-btn',
  '.rsvp-card',
  '.cd-label','.cd-grid','.cd-bottom',
  '.ft-with','.ft-names','.ft-gline','.ft-date'
].forEach(s=>document.querySelectorAll(s).forEach(el=>io.observe(el)));

/* COUNTDOWN */
const tick=()=>{
  const t=new Date('2026-04-26T10:00:00+05:30').getTime()-Date.now();
  if(t<=0){ ['cD','cH','cM','cS'].forEach(id=>document.getElementById(id).textContent='00'); return; }
  const pad=n=>String(n).padStart(2,'0');
  document.getElementById('cD').textContent=pad(Math.floor(t/86400000));
  document.getElementById('cH').textContent=pad(Math.floor(t%86400000/3600000));
  document.getElementById('cM').textContent=pad(Math.floor(t%3600000/60000));
  document.getElementById('cS').textContent=pad(Math.floor(t%60000/1000));
};
tick(); setInterval(tick,1000);

/* RSVP */
function doRSVP(c){
  const f=document.getElementById('rsvpForm');
  f.style.cssText='opacity:0;transition:opacity .5s ease;pointer-events:none;';
  setTimeout(()=>{
    f.style.display='none';
    document.getElementById('rsvpMsg').textContent=c==='yes'
      ?'We look forward to celebrating with you.'
      :'We will miss your presence. Thank you.';
    document.getElementById('rsvpDone').classList.add('show');
  },520);
}
</script>

