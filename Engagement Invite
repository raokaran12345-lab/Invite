<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Karan & Reshma · 26 April 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@200;300;400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

:root {
–black: #0B0B0B;
–gold: #D4AF37;
–ivory: #F8F5F0;
–dim: rgba(248,245,240,0.45);
}

html { scroll-behavior:smooth; }
body {
background:var(–black);
color:var(–ivory);
font-family:‘Inter’,sans-serif;
font-weight:300;
overflow-x:hidden;
}

::-webkit-scrollbar { width:2px; }
::-webkit-scrollbar-track { background:var(–black); }
::-webkit-scrollbar-thumb { background:var(–gold); }

/* ── PROGRESS ── */
#prog {
position:fixed; top:0; left:0; height:1px;
background:linear-gradient(90deg,transparent,var(–gold),transparent);
width:0%; z-index:100; transition:width .1s;
}

/* ── NAV ── */
nav {
position:fixed; top:0; left:0; right:0;
display:flex; align-items:center; justify-content:center;
padding:28px 48px; z-index:50;
}
.nav-logo {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:12px; letter-spacing:5px; text-transform:uppercase;
color:rgba(248,245,240,0.35);
}

/* ══ HERO ══ */
#hero {
height:100vh; display:flex; flex-direction:column;
align-items:center; justify-content:center;
overflow:hidden; position:relative; background:var(–black);
}

.hero-bg {
position:absolute; inset:0;
background:
radial-gradient(ellipse 80% 60% at 50% 30%,rgba(212,175,55,.07) 0%,transparent 70%),
radial-gradient(ellipse 50% 40% at 50% 85%,rgba(212,175,55,.04) 0%,transparent 60%);
animation:hglow 9s ease-in-out infinite alternate;
}
@keyframes hglow {
from { opacity:.6; transform:scale(1); }
to   { opacity:1;  transform:scale(1.05); }
}

.mandap-wrap {
position:absolute; bottom:0; left:50%; transform:translateX(-50%);
width:min(680px,88vw);
opacity:0; animation:fadeUp 2.5s cubic-bezier(.16,1,.3,1) .3s forwards;
}

.hero-content {
position:relative; z-index:2; text-align:center;
display:flex; flex-direction:column; align-items:center;
}
.hero-name {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:clamp(68px,13vw,150px); line-height:.9; letter-spacing:-2px;
color:var(–ivory); opacity:0;
}
.hero-name.k { animation:fadeDown 1.4s cubic-bezier(.16,1,.3,1) .4s forwards; }
.hero-name.r { animation:fadeUp  1.4s cubic-bezier(.16,1,.3,1) .7s forwards; }

.hero-amp {
font-family:‘Playfair Display’,serif; font-style:italic; font-weight:300;
font-size:clamp(28px,4.5vw,52px); color:var(–gold);
margin:10px 0; opacity:0; animation:fadeIn 1.2s ease 1.1s forwards;
}

.hero-div {
width:0; height:1px; margin:32px auto;
background:linear-gradient(90deg,transparent,var(–gold),transparent);
animation:expand 1.4s cubic-bezier(.16,1,.3,1) 1.5s forwards;
}

.hero-tag {
font-size:clamp(10px,1.5vw,13px); font-weight:200; letter-spacing:6px;
text-transform:uppercase; color:var(–dim);
opacity:0; animation:fadeIn 1.2s ease 2s forwards;
}
.hero-date-txt {
margin-top:12px; font-size:clamp(11px,1.6vw,14px); font-weight:200;
letter-spacing:4px; text-transform:uppercase; color:rgba(212,175,55,.65);
opacity:0; animation:fadeIn 1.2s ease 2.4s forwards;
}

.scroll-cue {
position:absolute; bottom:36px; left:50%; transform:translateX(-50%);
display:flex; flex-direction:column; align-items:center; gap:8px;
opacity:0; animation:fadeIn 1s ease 3.2s forwards;
}
.scroll-cue span { font-size:8px; letter-spacing:4px; text-transform:uppercase; color:var(–dim); }
.scroll-line {
width:1px; height:44px;
background:linear-gradient(to bottom,var(–gold),transparent);
animation:spulse 2s ease-in-out infinite;
}
@keyframes spulse { 0%,100%{opacity:.3;} 50%{opacity:1;} }

/* ══ QUOTE ══ */
#quote {
min-height:100vh; display:flex; align-items:center; justify-content:center;
background:linear-gradient(180deg,var(–black) 0%,#100e0a 50%,var(–ivory) 100%);
padding:100px 24px;
}
.quote-inner { text-align:center; max-width:680px; }
.quote-text {
font-family:‘Playfair Display’,serif; font-style:italic; font-weight:300;
font-size:clamp(26px,5vw,50px); line-height:1.45; color:var(–black);
opacity:0; transform:translateY(40px);
transition:opacity 1.4s ease, transform 1.4s ease;
}
.quote-text.vis { opacity:1; transform:translateY(0); }
.quote-line {
width:0; height:1px; background:var(–gold); margin:40px auto;
transition:width 1.8s cubic-bezier(.16,1,.3,1) .3s;
}
.quote-line.vis { width:80px; }

/* ══ CEREMONY ══ */
#ceremony {
background:var(–ivory); min-height:100vh;
display:flex; align-items:center; justify-content:center;
padding:100px 24px; overflow:hidden; position:relative;
}
.ceremony-accent {
position:absolute; inset:0;
background:
radial-gradient(ellipse 50% 50% at 80% 20%,rgba(212,175,55,.08) 0%,transparent 60%),
radial-gradient(ellipse 40% 40% at 20% 80%,rgba(212,175,55,.05) 0%,transparent 60%);
}
.ceremony-inner {
position:relative; z-index:2; text-align:center;
max-width:820px; display:flex; flex-direction:column; align-items:center; gap:28px;
}
.clabel {
font-size:10px; font-weight:400; letter-spacing:6px; text-transform:uppercase;
color:var(–gold); opacity:0; transform:translateY(20px);
transition:all 1s ease;
}
.clabel.vis { opacity:1; transform:translateY(0); }
.cheadline {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:clamp(40px,8vw,92px); line-height:1.05; color:var(–black);
letter-spacing:-1px; opacity:0; transform:translateY(30px);
transition:all 1.2s cubic-bezier(.16,1,.3,1) .2s;
}
.cheadline.vis { opacity:1; transform:translateY(0); }
.cdetails {
font-size:clamp(13px,2vw,16px); font-weight:200; letter-spacing:2px;
color:rgba(11,11,11,.45); opacity:0; transform:translateY(20px);
transition:all 1s ease .5s;
}
.cdetails.vis { opacity:1; transform:translateY(0); }
.jasmine {
opacity:0; transition:opacity 1.2s ease .7s;
}
.jasmine.vis { opacity:1; }

/* ══ VENUE ══ */
#venue {
background:var(–black); min-height:100vh;
display:grid; grid-template-columns:1fr 1fr; overflow:hidden;
}
@media(max-width:700px){ #venue{ grid-template-columns:1fr; } }

.venue-vis {
position:relative; min-height:55vh; overflow:hidden;
}
.venue-vis-bg {
position:absolute; inset:-5%;
background:
linear-gradient(135deg,rgba(212,175,55,.1) 0%,transparent 50%),
radial-gradient(ellipse 70% 70% at 45% 45%,rgba(212,175,55,.07) 0%,transparent 70%),
#0d0b09;
transition:transform 9s ease;
}
.venue-vis:hover .venue-vis-bg { transform:scale(1.06); }
.venue-illus {
position:absolute; inset:0;
display:flex; align-items:center; justify-content:center;
}

.venue-txt {
display:flex; flex-direction:column; justify-content:center; align-items:flex-start;
padding:clamp(44px,8vw,110px); gap:22px;
}
.vlabel {
font-size:10px; letter-spacing:6px; text-transform:uppercase; color:var(–gold);
opacity:0; transform:translateX(24px); transition:all 1s ease;
}
.vlabel.vis { opacity:1; transform:translateX(0); }
.vname {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:clamp(26px,4vw,46px); line-height:1.2; color:var(–ivory);
opacity:0; transform:translateX(24px);
transition:all 1.2s cubic-bezier(.16,1,.3,1) .2s;
}
.vname.vis { opacity:1; transform:translateX(0); }
.vaddr {
font-size:14px; font-weight:200; line-height:1.9; color:var(–dim);
opacity:0; transform:translateX(24px); transition:all 1s ease .4s;
}
.vaddr.vis { opacity:1; transform:translateX(0); }
.map-btn {
display:inline-flex; align-items:center; gap:10px;
padding:13px 26px; border:1px solid rgba(212,175,55,.35); color:var(–gold);
font-size:11px; font-weight:300; letter-spacing:3px; text-transform:uppercase;
text-decoration:none; cursor:pointer; background:transparent;
opacity:0; transform:translateX(24px);
transition:opacity 1s ease .6s, transform 1s ease .6s, background .4s, box-shadow .4s, border-color .4s;
}
.map-btn.vis { opacity:1; transform:translateX(0); }
.map-btn:hover {
background:rgba(212,175,55,.07); border-color:rgba(212,175,55,.6);
box-shadow:0 0 24px rgba(212,175,55,.1);
}

/* ══ RSVP ══ */
#rsvp {
background:var(–ivory); min-height:100vh;
display:flex; align-items:center; justify-content:center; padding:100px 24px;
}
.rsvp-card {
background:#fff; border-radius:4px;
padding:clamp(44px,6vw,76px) clamp(36px,6vw,76px);
max-width:540px; width:100%;
box-shadow:0 2px 8px rgba(0,0,0,.04),0 20px 56px rgba(0,0,0,.08),0 0 0 1px rgba(212,175,55,.1);
text-align:center;
opacity:0; transform:translateY(44px);
transition:all 1.4s cubic-bezier(.16,1,.3,1);
}
.rsvp-card.vis { opacity:1; transform:translateY(0); }
.rsvp-gline { width:40px; height:1px; background:var(–gold); margin:0 auto 28px; }
.rsvp-h {
font-family:‘Playfair Display’,serif; font-style:italic; font-weight:300;
font-size:clamp(20px,3.5vw,30px); color:var(–black); line-height:1.4; margin-bottom:8px;
}
.rsvp-sub {
font-size:12px; font-weight:200; letter-spacing:1px; color:rgba(11,11,11,.38); margin-bottom:36px;
}
.rsvp-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
.rbtn {
padding:13px 30px; font-size:11px; font-weight:300; letter-spacing:3px;
text-transform:uppercase; cursor:pointer; border:none; outline:none;
font-family:‘Inter’,sans-serif; transition:all .5s ease;
}
.rbtn.yes { background:var(–black); color:var(–ivory); }
.rbtn.yes:hover { background:#1a1a1a; transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,.2); }
.rbtn.no { background:transparent; color:var(–black); border:1px solid rgba(11,11,11,.18); }
.rbtn.no:hover { border-color:rgba(11,11,11,.5); transform:translateY(-2px); }
.rsvp-wa { margin-top:28px; font-size:10px; font-weight:200; letter-spacing:2px; color:rgba(11,11,11,.28); text-transform:uppercase; }
.rsvp-wa a { color:var(–gold); text-decoration:none; border-bottom:1px solid rgba(212,175,55,.3); transition:border-color .3s; }
.rsvp-wa a:hover { border-color:var(–gold); }
.rsvp-confirm { display:none; flex-direction:column; align-items:center; gap:14px; }
.rsvp-confirm.show { display:flex; }
.rsvp-icon { font-size:28px; opacity:0; animation:fadeIn .8s ease .2s forwards; }
.rsvp-ctxt {
font-family:‘Playfair Display’,serif; font-style:italic; font-size:21px; color:var(–black);
opacity:0; animation:fadeIn .8s ease .5s forwards;
}

/* ══ COUNTDOWN ══ */
#countdown {
background:var(–black); min-height:100vh;
display:flex; align-items:center; justify-content:center;
flex-direction:column; gap:20px; padding:100px 24px; text-align:center; position:relative;
}
.cd-bg {
position:absolute; inset:0;
background:radial-gradient(ellipse 55% 40% at 50% 50%,rgba(212,175,55,.04) 0%,transparent 70%);
}
.cd-label {
position:relative; z-index:2;
font-size:10px; font-weight:200; letter-spacing:7px; text-transform:uppercase;
color:var(–gold); opacity:0; transition:opacity 1s ease;
}
.cd-label.vis { opacity:1; }
.cd-grid {
position:relative; z-index:2;
display:flex; gap:clamp(20px,5vw,60px); align-items:flex-end;
opacity:0; transform:translateY(24px);
transition:all 1.2s cubic-bezier(.16,1,.3,1) .2s;
}
.cd-grid.vis { opacity:1; transform:translateY(0); }
.ci { display:flex; flex-direction:column; align-items:center; gap:6px; }
.cv {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:clamp(52px,9vw,110px); line-height:1; color:var(–ivory);
letter-spacing:-2px; min-width:clamp(64px,10vw,120px); text-align:center;
}
.cl { font-size:9px; font-weight:200; letter-spacing:5px; text-transform:uppercase; color:var(–gold); }
.cs {
font-family:‘Playfair Display’,serif; font-size:clamp(28px,4vw,56px);
color:rgba(212,175,55,.25); line-height:1; padding-bottom:6px;
}
.cd-bottom {
position:relative; z-index:2;
font-family:‘Playfair Display’,serif; font-style:italic; font-weight:300;
font-size:clamp(15px,2.5vw,22px); color:var(–dim); margin-top:10px;
opacity:0; transition:opacity 1s ease .4s;
}
.cd-bottom.vis { opacity:1; }

/* ══ FOOTER ══ */
footer {
background:var(–black);
border-top:1px solid rgba(212,175,55,.07);
min-height:65vh; display:flex; flex-direction:column;
align-items:center; justify-content:center;
gap:20px; text-align:center; padding:80px 24px; position:relative;
}
.ft-shimmer {
position:absolute; top:0; left:0; right:0; height:1px;
background:linear-gradient(90deg,transparent 0%,var(–gold) 50%,transparent 100%);
animation:shim 5s ease-in-out infinite; opacity:0;
}
@keyframes shim { 0%,100%{transform:scaleX(0);opacity:0;} 50%{transform:scaleX(1);opacity:.55;} }

.ft-with {
font-size:10px; font-weight:200; letter-spacing:6px; text-transform:uppercase; color:var(–dim);
opacity:0; transition:opacity 1s ease;
}
.ft-with.vis { opacity:1; }
.ft-names {
font-family:‘Playfair Display’,serif; font-weight:300;
font-size:clamp(30px,6vw,70px); color:var(–ivory); letter-spacing:-1px;
opacity:0; transform:translateY(20px); transition:all 1.4s cubic-bezier(.16,1,.3,1) .2s;
}
.ft-names.vis { opacity:1; transform:translateY(0); }
.ft-gline {
width:0; height:1px;
background:linear-gradient(90deg,transparent,var(–gold),transparent);
transition:width 2s cubic-bezier(.16,1,.3,1) .4s;
}
.ft-gline.vis { width:120px; }
.ft-date {
font-size:11px; font-weight:200; letter-spacing:5px; text-transform:uppercase;
color:rgba(212,175,55,.45); opacity:0; transition:opacity 1s ease .6s;
}
.ft-date.vis { opacity:1; }
.ft-micro { margin-top:36px; font-size:9px; font-weight:200; letter-spacing:2px; color:rgba(248,245,240,.12); }

/* ── KEYFRAMES ── */
@keyframes fadeIn  { from{opacity:0;} to{opacity:1;} }
@keyframes fadeUp  { from{opacity:0;transform:translateY(40px);} to{opacity:1;transform:translateY(0);} }
@keyframes fadeDown{ from{opacity:0;transform:translateY(-40px);}to{opacity:1;transform:translateY(0);} }
@keyframes expand  { from{width:0;} to{width:110px;} }
</style>

</head>
